# Variables de entorno — AgroSmart Andino
# IMPORTANTE: Copiar este archivo como .env y completar los valores reales
# NUNCA subir el archivo .env al repositorio (está en .gitignore)

# ── AWS Credentials (se obtienen de AWS Academy Lab) ──
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID_HERE
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY_HERE
AWS_SESSION_TOKEN=YOUR_SESSION_TOKEN_HERE
AWS_DEFAULT_REGION=us-east-1

# ── S3 ──
S3_BUCKET_NAME=agrosmart-andino-demo

# ── Cassandra (Cloud9) ──
CASSANDRA_HOST=127.0.0.1
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=agrosmart_andino

# ── NASA POWER API ──
# No requiere API key — es pública y gratuita
NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api/temporal/daily/point
